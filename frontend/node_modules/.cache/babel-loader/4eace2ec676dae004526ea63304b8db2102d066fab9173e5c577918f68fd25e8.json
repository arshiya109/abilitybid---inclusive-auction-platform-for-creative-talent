{"ast":null,"code":"import{API_BASE}from'../services/api';export const getImageUrl=imagePath=>{if(!imagePath)return'';if(imagePath.startsWith('http')||imagePath.startsWith('data:'))return imagePath;const normalized=imagePath.replace(/\\\\/g,'/').replace(/^\\/+/,'');const relativePath=normalized.startsWith('uploads/')?normalized:`uploads/${normalized}`;const base=API_BASE||'';return`${base}/${relativePath}`.replace(/([^:]\\/)\\/+/g,'$1');};","map":{"version":3,"names":["API_BASE","getImageUrl","imagePath","startsWith","normalized","replace","relativePath","base"],"sources":["C:/Users/misba/OneDrive/Attachments/AbilityBid/frontend/src/utils/getImageUrl.js"],"sourcesContent":["import { API_BASE } from '../services/api';\r\n\r\nexport const getImageUrl = (imagePath) => {\r\n  if (!imagePath) return '';\r\n  if (imagePath.startsWith('http') || imagePath.startsWith('data:')) return imagePath;\r\n\r\n  const normalized = imagePath.replace(/\\\\/g, '/').replace(/^\\/+/, '');\r\n  const relativePath = normalized.startsWith('uploads/')\r\n    ? normalized\r\n    : `uploads/${normalized}`;\r\n\r\n  const base = API_BASE || '';\r\n  return `${base}/${relativePath}`.replace(/([^:]\\/)\\/+/g, '$1');\r\n};\r\n"],"mappings":"AAAA,OAASA,QAAQ,KAAQ,iBAAiB,CAE1C,MAAO,MAAM,CAAAC,WAAW,CAAIC,SAAS,EAAK,CACxC,GAAI,CAACA,SAAS,CAAE,MAAO,EAAE,CACzB,GAAIA,SAAS,CAACC,UAAU,CAAC,MAAM,CAAC,EAAID,SAAS,CAACC,UAAU,CAAC,OAAO,CAAC,CAAE,MAAO,CAAAD,SAAS,CAEnF,KAAM,CAAAE,UAAU,CAAGF,SAAS,CAACG,OAAO,CAAC,KAAK,CAAE,GAAG,CAAC,CAACA,OAAO,CAAC,MAAM,CAAE,EAAE,CAAC,CACpE,KAAM,CAAAC,YAAY,CAAGF,UAAU,CAACD,UAAU,CAAC,UAAU,CAAC,CAClDC,UAAU,CACV,WAAWA,UAAU,EAAE,CAE3B,KAAM,CAAAG,IAAI,CAAGP,QAAQ,EAAI,EAAE,CAC3B,MAAO,GAAGO,IAAI,IAAID,YAAY,EAAE,CAACD,OAAO,CAAC,cAAc,CAAE,IAAI,CAAC,CAChE,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}